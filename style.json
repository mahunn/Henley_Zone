{
    "project": {
      "name": "ANS Fashion Clone",
      "description": "E-commerce fashion website inspired by ansfashion.com with sky blue color theme",
      "instructions_for_claude": "Build a full-stack styled fashion e-commerce site using the structure below. Use a sky blue light color palette. The user will provide their own colors — use CSS variables throughout so colors are easy to swap. Use placeholder images from https://placehold.co. All prices in Taka (৳). Make it fully responsive."
    },
  
    "theme": {
      "note": "User will supply final colors. Use these as CSS variable names.",
      "css_variables": {
        "--color-primary": "#0ea5e9",
        "--color-primary-dark": "#0284c7",
        "--color-primary-light": "#e0f2fe",
        "--color-accent": "#f59e0b",
        "--color-bg": "#f0f9ff",
        "--color-surface": "#ffffff",
        "--color-text-primary": "#0f172a",
        "--color-text-secondary": "#64748b",
        "--color-border": "#e2e8f0",
        "--color-badge-sale": "#ef4444",
        "--color-badge-new": "#22c55e",
        "--color-badge-top": "#f59e0b",
        "--color-badge-flash": "#8b5cf6"
      },
      "fonts": {
        "heading": "Playfair Display",
        "body": "DM Sans"
      }
    },
  
