        "layout": "two_column",
        "sections": [
  
          {
            "id": "breadcrumb",
            "type": "breadcrumb",
            "items": ["Home", "Shop", "{product_name}"],
            "separator": ">",
            "style": { "font_size": "13px", "color": "var(--color-text-secondary)", "padding": "12px 0" }
          },
  
          {
            "id": "product_main",
            "type": "two_column_layout",
            "gap": "48px",
            "left_column": {
              "width": "45%",
              "components": [
                {
                  "id": "main_image",
                  "type": "image_gallery",
                  "badge_position": "top-left",
                  "main_image_style": { "border_radius": "12px", "width": "100%", "aspect_ratio": "4/5" },
                  "thumbnail_strip": {
                    "position": "below",
                    "thumbnail_size": "70px",
                    "gap": "8px",
                    "active_border": "2px solid var(--color-primary)"
                  }
                }
              ]
            },
            "right_column": {
              "width": "55%",
              "components": [
                {
                  "id": "product_title",
                  "type": "heading",
                  "level": "h1",
                  "style": { "font": "var(--font-heading)", "font_size": "28px", "font_weight": "700", "color": "var(--color-text-primary)", "letter_spacing": "0.02em" }
                },
                {
                  "id": "rating_stock_row",
                  "type": "flex_row",
                  "align": "center",
                  "gap": "16px",
                  "children": [
                    { "type": "stars", "value": "{rating}", "max": 5, "color": "var(--color-accent)" },
                    { "type": "badge", "content": "In Stock ({quantity} items)", "style": { "color": "var(--color-badge-new)", "font_size": "13px" } }
                  ]
                },
                {
                  "id": "price_display",
                  "type": "price_block",
                  "current_price_style": { "font_size": "28px", "font_weight": "700", "color": "var(--color-primary-dark)" },
                  "original_price_style": { "font_size": "16px", "text_decoration": "line-through", "color": "var(--color-text-secondary)" },
                  "currency_symbol": "৳"
