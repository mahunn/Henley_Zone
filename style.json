        "shared_components": {
          "product_card": {
            "description": "Reusable product card used in all product rows",
            "elements": [
              {
                "id": "discount_badge",
                "type": "badge",
                "position": "top-left",
                "content": "-{discount_percent}%",
                "visible_when": "discount_percent != null",
                "style": { "background": "var(--color-badge-sale)", "color": "#fff", "font_size": "12px", "border_radius": "4px", "padding": "2px 6px" }
              },
              {
                "id": "type_badge",
                "type": "badge",
                "position": "top-left_below_discount",
                "content": "{badge_type}",
                "visible_when": "badge != null",
                "badge_types": {
                  "Best": { "background": "#3b82f6" },
                  "Top": { "background": "var(--color-badge-top)" },
                  "Flash deal": { "background": "var(--color-badge-flash)" },
                  "Feature": { "background": "var(--color-primary)" },
                  "New": { "background": "var(--color-badge-new)" }
                }
              },
              {
                "id": "product_image",
                "type": "image",
                "aspect_ratio": "3/4",
                "object_fit": "cover"
              },
              {
                "id": "hover_actions",
                "type": "action_icons",
                "position": "bottom-right on hover",
                "icons": [
                  { "icon": "heart", "action": "add_to_wishlist" },
                  { "icon": "bar-chart-2", "action": "compare" },
                  { "icon": "shopping-cart", "action": "add_to_cart" }
                ]
              },
              {
                "id": "category_label",
                "type": "text",
                "content": "{category}",
                "style": { "font_size": "11px", "color": "var(--color-text-secondary)", "text_transform": "uppercase", "letter_spacing": "0.05em" }
              },
              {
                "id": "product_name",
                "type": "link",
                "content": "{name}",
                "style": { "font_size": "14px", "color": "var(--color-text-primary)", "font_weight": "500" }
              },
              {
                "id": "star_rating",
                "type": "stars",
                "max": 5,
                "value": "{rating}",
                "color": "var(--color-accent)"
              },
              {
                "id": "price_block",
                "type": "price",
                "current_price_style": { "font_weight": "700", "color": "var(--color-primary-dark)" },
                "original_price_style": { "text_decoration": "line-through", "color": "var(--color-text-secondary)", "font_size": "13px" },
                "currency_symbol": "৳"
              }
            ]
          }
        }
      },
  
